/* 全局样式（ZHANG YIXIAO - p2423046） */
page {
  font-family: "Arial", "Microsoft YaHei";
  background-color: #f5f5f5;
  padding: 10rpx;
}

/* 筛选按钮样式 */
.filter-btn {
  background-color: #ff6f4a;
  color: white;
  border-radius: 8rpx;
  margin: 5rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border: none;
}

/* 重置按钮样式 */
.reset-btn {
  background-color: #666666 !important;
}

/* 美食卡片样式 */
.food-card {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin: 10rpx 0;
  box-shadow: 0 2rpx 6rpx #eeeeee;
}

/* 收藏按钮样式 */
.collect-btn {
  background-color: #ff6f4a;
  color: white;
  border-radius: 8rpx;
  margin-top: 15rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  border: none;
}

/* 已收藏按钮样式 */
.collected-btn {
  background-color: #ff3333 !important;
}