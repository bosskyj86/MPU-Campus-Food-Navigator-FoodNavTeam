<view class="container">
  <!-- 筛选区域 -->
  <view class="filter-container" style="margin: 20rpx 0; display: flex; flex-wrap: wrap; align-items: center;">
    <view style="font-size: 26rpx; margin-right: 10rpx; font-weight: bold;">Scene:</view>
    <button class="filter-btn" bindtap="filterByScene" data-scene="Breakfast/Lunch/Dinner">Meal</button>
    <button class="filter-btn" bindtap="filterByScene" data-scene="Coffee/Snack">Coffee/Snack</button>

    <view style="font-size: 26rpx; margin-left: 20rpx; margin-right: 10rpx; font-weight: bold;">Cost:</view>
    <button class="filter-btn" bindtap="filterByCost" data-cost="low">≤30MOP</button>
    <button class="filter-btn" bindtap="filterByCost" data-cost="mid">30-60MOP</button>

    <button class="filter-btn reset-btn" bindtap="resetFilter">Reset</button>
  </view>

  <!-- 我的收藏按钮 -->
  <button class="filter-btn" style="width: 100%; margin: 10rpx 0;" bindtap="showCollection">My Collection</button>

  <!-- 美食列表 -->
  <view class="food-list">
    <block wx:for="{{filteredFoodList}}" wx:key="id">
      <view class="food-card">
        <view style="font-size: 32rpx; font-weight: bold; color: #ff6f4a; margin-bottom: 10rpx;">{{item.name}}</view>
        <view style="font-size: 24rpx; margin: 5rpx 0;">📍 Location: {{item.location}}</view>
        <view style="font-size: 24rpx; margin: 5rpx 0;">💰 Price: {{item.average_cost_mop}} MOP</view>
        <view style="font-size: 24rpx; margin: 5rpx 0;">🍽️ Recommended: {{item.recommended_dishes}}</view>
        <view style="font-size: 22rpx; color: #666; margin: 5rpx 0;">⏰ Hours: {{item.business_hours}}</view>
        <button class="collect-btn {{item.collected ? 'collected-btn' : ''}}" bindtap="toggleCollect" data-id="{{item.id}}">
          {{item.collected ? 'Collected' : 'Collect'}}
        </button>
      </view>
    </block>
  </view>

  <!-- 无数据提示 -->
  <view wx:if="{{filteredFoodList.length === 0}}" style="text-align: center; margin-top: 50rpx; font-size: 24rpx; color: #999;">
    No food spots match your filter!
  </view>
</view>